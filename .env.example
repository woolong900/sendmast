NODE_ENV=development

# ===== API =====
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:5173
TRACKING_BASE_URL=http://localhost:4000

# ===== PostgreSQL =====
DATABASE_URL=postgresql://sendmast:sendmast@localhost:5432/sendmast?schema=public
DATABASE_SHADOW_URL=postgresql://sendmast:sendmast@localhost:5432/sendmast_shadow?schema=public

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== ClickHouse =====
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=sendmast
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ===== MinIO (S3) =====
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=sendmast
S3_SECRET_KEY=sendmast-secret
S3_BUCKET=sendmast-uploads
S3_PUBLIC_BUCKET=sendmast-public
# Base URL (or path) for public bucket asset URLs. In dev we use a path-relative
# value so URLs are port-less — Easy Email's canvas inline-style parser breaks
# on URLs containing `:port`. The web app's Vite dev server proxies this path
# back to MinIO. In prod, set this to a port-less CDN URL such as
# https://cdn.example.com/public.
S3_PUBLIC_BASE_URL=/sendmast-public

# ===== JWT =====
JWT_SECRET=change-me-in-production-please-use-32-bytes-minimum
JWT_REFRESH_SECRET=change-me-in-production-too-please-use-32-bytes-minimum
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=12h

# ===== Email Channel =====
# Email transport is now selected dynamically per sender domain via the
# AcsAccount table. A platform administrator must create at least one
# AcsAccount and bind it to each sender domain via the admin UI.
#   - For dev/MailHog: connection_string = "mailhog://localhost:1025"
#   - For Azure ACS:   connection_string = "<full ACS connection string>"

# Per-process send concurrency (BullMQ worker). Tune per host.
SEND_CONCURRENCY=8

# ===== Import worker =====
# Total in-flight import jobs across all tenants on this worker process.
IMPORT_CONCURRENCY=8
# Per-tenant cap. A tenant that queues more than this gets jobs delayed
# (5s) so other tenants keep their fair share of worker slots.
IMPORT_PER_ACCOUNT=2

# ===== Tracking =====
TRACKING_TOKEN_SECRET=change-me-tracking-token-secret-please

# ===== Webhooks =====
# Shared secret for the Azure Event Grid webhook. When set, the endpoint
# requires `?key=<value>`; configure the SAME value on the Event Grid
# subscription endpoint URL. Leave empty to disable the check (NOT recommended
# in production — forged delivery/bounce events could skew stats / suppress
# real contacts). Generate with: openssl rand -hex 24
EVENTGRID_WEBHOOK_KEY=

# ===== Shouqianba (收钱吧, self-service quota top-up) =====
# All optional at boot — until TERMINAL_SN / TERMINAL_KEY are filled, the
# "购买额度" button returns 503 with "支付通道未配置"; admin CRUD still works.
#
# Provisioning flow (one-shot, off-box):
#   1. Get vendor_sn / vendor_key / app_id from Shouqianba developer signup.
#   2. In sp.shouqianba.com, create a 门店 + 终端, copy the 激活码.
#   3. Run /scripts/shouqianba-activate.py (or curl /terminal/activate
#      signed with vendor_sn/vendor_key) — response gives terminal_sn /
#      terminal_key. Persist them here; activation only needs to run again
#      when keys are rotated by support.
SHOUQIANBA_GATEWAY=https://vsi-api.shouqianba.com
SHOUQIANBA_APP_ID=
SHOUQIANBA_VENDOR_SN=
SHOUQIANBA_VENDOR_KEY=
SHOUQIANBA_TERMINAL_SN=
SHOUQIANBA_TERMINAL_KEY=

# Airwallex hosted checkout. Use `demo` with sandbox credentials locally and
# `production` with live credentials after payment methods are activated.
AIRWALLEX_ENV=demo
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
# Generated for the webhook notification URL in the Airwallex web app.
AIRWALLEX_WEBHOOK_SECRET=

# ===== Frontend (Vite) =====
VITE_API_BASE_URL=http://localhost:4000
