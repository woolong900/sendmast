{
  "name": "@sendmast/worker-shop-sync",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit --tsBuildInfoFile node_modules/.cache/.tsbuildinfo"
  },
  "dependencies": {
    "@clickhouse/client": "^1.8.1",
    "@prisma/client": "^5.22.0",
    "@sendmast/clickhouse": "workspace:*",
    "@sendmast/db": "workspace:*",
    "@sendmast/shared": "workspace:*",
    "@sendmast/shopyy": "workspace:*",
    "bullmq": "^5.21.2",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "dotenv-cli": "^7.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
