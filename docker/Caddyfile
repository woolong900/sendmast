# SendMast Caddy reverse proxy + SPA host + apex marketing site
# (Cloudflare Origin Cert mode).
#
# `{$DOMAIN}` is interpolated by Caddy from the container env at startup.
# Set DOMAIN=app.sendmast.example.com in `.env.production`.
#
# TLS: this config uses a Cloudflare Origin Certificate, which the CF
# edge trusts but the public internet does not. Browsers must reach the
# server through Cloudflare (orange cloud / proxied DNS record) — direct
# IP access will show a cert warning by design. The cert files must be
# present at the paths below before Caddy starts; see DEPLOY.md §"Cloudflare
# setup" for the dashboard click-path. The cert SAN must cover BOTH the
# app subdomain and the apex (the default CF Origin Cert with hostnames
# `*.sendmast.com, sendmast.com` does so out of the box).
#
# Site map:
#   sendmast.com         → /srv/marketing    (static landing page)
#   www.sendmast.com     → 301 to apex
#   {$DOMAIN} (app.…)    → SPA + API reverse proxy (everything below)
#
# {$DOMAIN} routing:
#   /api/*               → api:4000          (NestJS HTTP)
#   /t/*                 → api:4000          (tracking pixels / unsubscribe)
#   /health              → api:4000          (liveness probe)
#   /sendmast-public/*   → minio:9000        (public-bucket assets — uploaded
#                                             images, email thumbnails, etc.)
#   everything else      → /srv/web (SPA)    (index.html SPA fallback for
#                                             react-router deep links)

# Global options: trust Cloudflare edge IPs so Caddy (and the API
# downstream) sees the real client IP from CF-Connecting-IP instead
# of CF's edge addresses. Refresh annually from cloudflare.com/ips —
# CF rarely changes ranges but occasionally adds new ones.
{
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
		client_ip_headers CF-Connecting-IP X-Forwarded-For
	}
}

# ─── Apex: marketing landing page ───────────────────────────────────────────
# Static one-pager (Tailwind CDN, no build). Edit marketing/index.html in the
# repo and rebuild the caddy image to ship.
sendmast.com {
	tls /etc/caddy/certs/origin-cert.pem /etc/caddy/certs/origin-key.pem
	encode gzip zstd

	root * /srv/marketing
	file_server

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options SAMEORIGIN
		# index.html is the only un-hashed entry; let CF and browsers
		# revalidate. Other static assets (none yet) can use a stronger
		# policy when added.
		Cache-Control "public, max-age=300, must-revalidate"
	}

	log {
		output stdout
		format console
	}
}

# www → apex (canonical-host redirect, 301).
www.sendmast.com {
	tls /etc/caddy/certs/origin-cert.pem /etc/caddy/certs/origin-key.pem
	redir https://sendmast.com{uri} 301
}

# ─── API subdomain (third-party integrations) ───────────────────────────────
# Dedicated host for webhooks (Azure Event Grid, payment providers) and
# future public REST surfaces. NestJS uses a global `/api` prefix; we rewrite
# inbound `api.sendmast.com/foo` → upstream `api:4000/api/foo` so external
# URLs stay clean (api.sendmast.com/webhooks/azure-event-grid) while the
# server code keeps its existing route shape unchanged.
#
# Browser-facing paths (SPA, /sendmast-public/*) intentionally NOT routed
# here — those stay on app.sendmast.com.
api.sendmast.com {
	tls /etc/caddy/certs/origin-cert.pem /etc/caddy/certs/origin-key.pem
	encode gzip zstd

	rewrite * /api{uri}
	reverse_proxy api:4000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
	}

	log {
		output stdout
		format console
	}
}

# ─── App subdomain (SaaS product) ───────────────────────────────────────────
{$DOMAIN} {
	# Cloudflare Origin Certificate. Issue once via CF Dashboard
	# (SSL/TLS → Origin Server → Create Certificate, default 15 year
	# validity, RSA 2048 or ECDSA P-256). Save:
	#   - cert+chain → /etc/caddy/certs/origin-cert.pem
	#   - private key → /etc/caddy/certs/origin-key.pem
	# Mounted read-only via docker-compose volume. Caddy hot-reloads
	# the cert when the file changes — no container restart needed.
	tls /etc/caddy/certs/origin-cert.pem /etc/caddy/certs/origin-key.pem

	encode gzip zstd

	# Serve API first; order matters because the SPA fallback at the bottom
	# would otherwise swallow `/api/*` requests as 404 → index.html.
	handle /api/* {
		reverse_proxy api:4000
	}
	handle /t/* {
		reverse_proxy api:4000
	}
	handle /health {
		reverse_proxy api:4000
	}

	# Public bucket assets. The API stores image upload URLs as
	# `/sendmast-public/<key>` — Caddy forwards the request as-is to
	# MinIO; MinIO resolves the bucket name from the path. URLs stay
	# port-less and origin-relative (Easy Email's canvas inline-style
	# parser breaks on URLs containing `:port`, see vite.config.ts).
	# SVG is intentionally blocked even for legacy uploads: active SVG content
	# on the app origin could execute script and read persisted auth tokens.
	@publicSvg path_regexp publicSvg ^/sendmast-public/.*\.svg$
	respond @publicSvg 404
	handle /sendmast-public/* {
		reverse_proxy minio:9000
	}

	# SPA: serve static files; any path that doesn't match a real file
	# returns index.html so client-side routing (react-router) handles it.
	handle {
		root * /srv/web

		# Cache policy. Caddy evaluates `header` matchers against the
		# *original* request path — BEFORE `try_files` rewrites SPA deep
		# links to /index.html — so we must match by what the client
		# actually sent. Vite emits all hashed bundles under /assets/*,
		# so use that as the fingerprint for "safe to cache forever";
		# everything else (index.html shell at /, deep links like
		# /login, /settings/*, /dashboard, …) must always revalidate
		# so a deploy is picked up on the next page load.
		@hashed path /assets/*
		header @hashed Cache-Control "public, max-age=31536000, immutable"
		@shell not path /assets/*
		header @shell Cache-Control "no-cache"

		try_files {path} /index.html
		file_server
	}

	# Security headers — modest defaults; tighten as the app evolves.
	# HSTS is set explicitly because Caddy only auto-enables it when it
	# manages the cert itself (i.e. ACME); with `tls <file>` it doesn't.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options SAMEORIGIN
	}

	# Access log to stdout so `docker compose logs caddy` works.
	log {
		output stdout
		format console
	}
}

# ─── Tracking domain pool ──────────────────────────────────────────────────
# Each `tracking_domains` row in Postgres needs a matching site block here so
# Caddy terminates TLS and reverse-proxies `/t/*` to the API. To avoid editing
# this file every time an admin adds a domain, we import a directory of
# auto-generated snippets. The admin UI's "复制 Caddy 片段" button outputs the
# exact contents of a file to drop into `docker/tracking.d/<domain>.caddy`,
# then `caddy reload` is enough — no rebuild.
#
# The directory is mounted read-only by docker-compose.prod.yml. Empty in dev
# / fresh deploys; the glob just no-ops in that case.
import /etc/caddy/tracking.d/*.caddy
