# ─── Production env template ──────────────────────────────────────────────────
# Copy to `.env.production` on the server, fill in real secrets, then:
#   chmod 600 .env.production            # never world-readable
#   docker compose --env-file .env.production -f docker/docker-compose.prod.yml up -d
#
# ALL `change-me-*` values MUST be replaced before going live. The compose
# file uses `${VAR:?set VAR in .env.production}` for the critical secrets so
# missing values fail loudly instead of booting an insecure stack.

NODE_ENV=production

# ─── Public-facing domain ──────────────────────────────────────────────────────
# Single hostname for SPA + API + tracking links. Caddy provisions a real
# Let's Encrypt cert for this name automatically. To run locally without TLS
# (smoke test), set DOMAIN=:80 — Caddy will serve plain HTTP on port 80.
DOMAIN=sendmast.example.com

# Where the API publishes its own URLs (used inside emails for tracking
# pixels and unsubscribe links). MUST match `https://$DOMAIN`.
API_BASE_URL=https://sendmast.example.com
WEB_BASE_URL=https://sendmast.example.com
TRACKING_BASE_URL=https://sendmast.example.com

# ─── Where on the host to keep data dirs ──────────────────────────────────────
# Bind-mounted by docker-compose. Backups should target this path.
DATA_ROOT=/var/lib/sendmast

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=sendmast
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=sendmast
# DATABASE_URL is what the API/workers read. Host is the compose service name.
DATABASE_URL=postgresql://sendmast:change-me-strong-postgres-password@postgres:5432/sendmast?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://default:change-me-strong-redis-password@redis:6379

# ─── ClickHouse ──────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=sendmast
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me-strong-clickhouse-password

# ─── S3 / MinIO ──────────────────────────────────────────────────────────────
# Service-to-service URL stays internal; external assets go through Caddy
# at /sendmast-public/<key>.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=change-me-minio-access-key
S3_SECRET_KEY=change-me-minio-secret-key-min-8-chars
S3_BUCKET=sendmast-uploads
S3_PUBLIC_BUCKET=sendmast-public
# Public asset URL prefix. Caddy proxies this path → MinIO. A path like
# `/sendmast-public` is resolved by the API against WEB_BASE_URL before being
# returned for email content, because delivered email images need absolute URLs.
S3_PUBLIC_BASE_URL=/sendmast-public

# ─── JWT secrets ─────────────────────────────────────────────────────────────
# Generate fresh values: `openssl rand -hex 32` (run once each).
JWT_SECRET=change-me-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-with-openssl-rand-hex-32
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=12h

# ─── Email tracking signing secret ───────────────────────────────────────────
# Signs unsubscribe / open / click tracking tokens. Same generator as JWT.
# Rotating this invalidates all in-flight tracking links — only do it during
# a maintenance window with no recent sends.
TRACKING_TOKEN_SECRET=change-me-with-openssl-rand-hex-32

# Required in production. Append `?key=<same value>` to the Azure Event Grid
# webhook endpoint URL. Generate with: `openssl rand -hex 32`
EVENTGRID_WEBHOOK_KEY=change-me-with-openssl-rand-hex-32

# ─── Worker concurrency ──────────────────────────────────────────────────────
# Per-process. Tune to host vCPU count and your ACS account quotas.
SEND_CONCURRENCY=8
IMPORT_CONCURRENCY=8
IMPORT_PER_ACCOUNT=2

# ─── Frontend build-time vars ────────────────────────────────────────────────
# Empty = same-origin (Caddy proxies /api). DO NOT change unless you split
# the web and api onto separate domains.
VITE_API_BASE_URL=

# ─── Quota payments ─────────────────────────────────────────────────────────
# Change to airwallex after the live account has online payment methods enabled.
QUOTA_PAYMENT_PROVIDER=shouqianba

# ─── Airwallex payments ──────────────────────────────────────────────────────
# Configure the webhook URL as:
#   https://$DOMAIN/api/payments/airwallex/webhook
# Subscribe at minimum to `payment_intent.succeeded`.
AIRWALLEX_ENV=production
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
# Optional for checkout, strongly recommended for immediate server-to-server
# payment confirmation. Obtain it when creating the webhook subscription.
AIRWALLEX_WEBHOOK_SECRET=
