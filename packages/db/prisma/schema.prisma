generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Identity & Tenancy
// ============================================================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  passwordHash    String    @map("password_hash")
  displayName     String?   @map("display_name")
  emailVerified   Boolean   @default(false) @map("email_verified")
  isPlatformAdmin Boolean   @default(false) @map("is_platform_admin")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  memberships             AccountUser[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@map("users")
}

/// Single-use, time-bound token a user redeems by clicking the activation
/// link sent at signup (or via "resend activation"). On redeem we set
/// `users.emailVerified = true` AND flip `accounts.status` from
/// `pending_activation` to `active`. Same hash-storage pattern as
/// PasswordResetToken — token plaintext never lands in the DB.
model EmailVerificationToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  requestedIp String?   @map("requested_ip")
  requestedUa String?   @map("requested_ua")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("email_verification_tokens")
}

/// Single-use, time-bound token a user redeems by clicking a link in a
/// "reset password" email. Stored as SHA-256 hash so a DB leak doesn't
/// equal account takeover.
model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  requestedIp String?   @map("requested_ip")
  requestedUa String?   @map("requested_ua")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_reset_tokens")
}

/// Singleton — only one row exists, primary key is hard-coded to 'singleton'.
/// Holds the platform-wide SMTP credentials used for sending system emails
/// (password reset, future welcome / quota-low / etc.). Per the user's
/// choice, the password is stored as plaintext readable by platform admins.
model SystemSmtpConfig {
  id          String   @id @default("singleton")
  host        String
  port        Int
  secure      Boolean  @default(true)
  username    String
  password    String
  fromName    String   @map("from_name")
  fromAddress String   @map("from_address")
  replyTo     String?  @map("reply_to")
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("system_smtp_config")
}

/// Self-service quota top-up: 9-tier pricing table editable in admin UI.
/// Each row is one purchasable bundle (emails + USD price). Pricing is
/// USD only — checkout charges CNY, so we convert USD→CNY at order creation using
/// FxService and snapshot the rate onto the order. `active=false` hides
/// a tier from buyers without breaking historical orders that reference it.
model QuotaPricingTier {
  id        String   @id @default(uuid()) @db.Uuid
  emails    Int
  priceUsd  Decimal  @map("price_usd") @db.Decimal(10, 2)
  active    Boolean  @default(true)
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders QuotaOrder[]

  @@index([active, sortOrder])
  @@map("quota_pricing_tiers")
}

/// Self-service top-up order. State machine: pending → paid (or failed /
/// cancelled). Crediting `Account.sendQuotaRemaining` happens exactly once
/// inside the same transaction that flips status → paid in the gateway
/// notify handler — `provider_order_id` UNIQUE makes the handler idempotent
/// against retries. `tier_id` is denormalized snapshot only; `emails` /
/// amounts are also captured at order time so later edits to the tier table
/// don't rewrite history.
model QuotaOrder {
  id              String    @id @default(uuid()) @db.Uuid
  accountId       String    @map("account_id") @db.Uuid
  tierId          String?   @map("tier_id") @db.Uuid
  emails          Int
  amountUsd       Decimal   @map("amount_usd") @db.Decimal(10, 2)
  /// CNY actually charged at order creation time. Gateway settles in CNY,
  /// so this is what the buyer's Alipay/WeChat is billed for.
  amountCny       Decimal   @map("amount_cny") @db.Decimal(10, 2)
  /// FX rate used to compute amountCny from amountUsd. Snapshot at order
  /// time so a later rate change doesn't rewrite history.
  fxRate          Decimal   @map("fx_rate") @db.Decimal(12, 6)
  status          String    @default("pending")
  /// Which gateway placed this order — `airwallex` for current orders,
  /// `shouqianba` / `alipay` for legacy ones. Default reflects history; new code always
  /// sets it explicitly.
  provider        String    @default("alipay")
  /// Gateway order reference (Airwallex PaymentIntent ID for current orders).
  /// UNIQUE so retried notify callbacks land
  /// on the same row.
  providerOrderId String    @unique @map("provider_order_id")
  /// Gateway's internal trade id, returned in the notify body once paid.
  providerTradeNo String?   @map("provider_trade_no")
  paidAt          DateTime? @map("paid_at")
  createdBy       String?   @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  account Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tier    QuotaPricingTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("quota_orders")
}

/// FX rate cache (history). Latest row per (base, quote) is the "current"
/// rate. Rows are inserted, never updated — we want an audit trail so a
/// disputed order can be reconciled against the rate that was actually
/// quoted that day. Source `frankfurter` = pulled from api.frankfurter.app
/// (ECB mid-rate, daily, free, no key); `manual` = admin force-refresh.
model FxRate {
  id        String   @id @default(uuid()) @db.Uuid
  base      String
  quote     String
  rate      Decimal  @db.Decimal(12, 6)
  source    String
  fetchedAt DateTime @map("fetched_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([base, quote, fetchedAt(sort: Desc)])
  @@map("fx_rates")
}

/// Pool of host names used to serve open-pixel / click-redirect / unsubscribe
/// URLs. Existing only to spread spam-complaint risk across multiple domains
/// instead of relying on the single primary app domain — if a tenant sends
/// abusive volume on one tracking domain, only that one gets blacklisted.
///
/// Selection (worker-sender): for each recipient we hash `recipient.id` and
/// pick `domains[hash % activeCount]`. Same recipient always gets the same
/// host across opens/clicks/unsubscribes, so analytics and consent flows
/// stay consistent for that user.
///
/// Pool empty → send fails (deliberate, surfaces config drift). No fallback
/// to the primary app host because the whole point is to keep the app host
/// out of email tracking.
///
/// Domain availability is enforced by the operator: each row needs a matching
/// Caddy site block on the server (see docker/tracking.d/) plus DNS pointing
/// at the server. We don't probe automatically — the admin marks `active`
/// only after they've confirmed the config works.
model TrackingDomain {
  id        String   @id @default(uuid()) @db.Uuid
  /// Bare hostname, no protocol/path. Stored lowercase.
  domain    String   @unique @db.VarChar(253)
  /// 'active'   — in rotation
  /// 'disabled' — taken out by an admin (e.g. blacklisted)
  /// Two-state for now; if we add automated DNS/TLS probing later we'll
  /// expand to pending/failed.
  status    String   @default("active") @db.VarChar(16)
  /// Free-form admin note (e.g. "purchased 2026-05, registrar Namecheap").
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("tracking_domains")
}

/// Editable email templates for system notifications. The `code` is a fixed
/// enum coupled to backend code that calls renderTemplate(code, vars) — admin
/// can edit subject/body but cannot add new codes (that needs a code change).
/// `variables` is the JSON list of `{{var}}` placeholders the body may use,
/// shown to the admin in the editor as available substitutions.
model NotificationTemplate {
  code        String   @id
  name        String
  description String?
  subject     String
  bodyHtml    String   @map("body_html") @db.Text
  variables   Json     @default("[]")
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("notification_templates")
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  tokenHash      String    @unique @map("token_hash")
  userAgent      String?   @map("user_agent")
  ip             String?
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  /// Workspace this token's access tokens grant. Nullable for legacy rows
  /// issued before the impersonation feature — refresh falls back to the
  /// user's first AccountUser membership in that case.
  accountId      String?   @map("account_id") @db.Uuid
  /// Set when a Platform Admin used this session to "代登录" another tenant.
  /// Stores the admin's own user id so refresh keeps the impersonation
  /// context alive across access-token rotations and the UI banner.
  impersonatedBy String?   @map("impersonated_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Account {
  id                  String        @id @default(uuid()) @db.Uuid
  name                String
  slug                String        @unique
  planCode            String        @default("free") @map("plan_code")
  /// Set at signup time when the visitor came in through /signup?ref=CODE.
  /// Used to attribute every future paid quota order back to a partner
  /// channel for commission accrual. Immutable after signup — admins can
  /// re-point manually via SQL if a mistake needs correcting, but no UI.
  referredByChannelId String?       @map("referred_by_channel_id") @db.Uuid
  /// Snapshot of when the attribution was first written. Equal to
  /// signup time for normal flow; useful for analytics ("how long
  /// from referral signup to first paid order").
  referredAt          DateTime?     @map("referred_at")
  /// Lifecycle state. New tenants land in `pending_activation` until the
  /// signup user clicks the activation link in their inbox; admin-only flip
  /// to `suspended` blocks all writes (read still works) until unsuspended.
  /// Enforcement: AccountWriteGuard interceptor checks suspended; the
  /// campaign create/start endpoints additionally check active.
  status              AccountStatus @default(pending_activation)
  /// Set the moment we flip status -> active. Useful for analytics ("how
  /// many tenants reach active in <24h"). NULL while pending_activation.
  activatedAt         DateTime?     @map("activated_at")
  /// Set when admin moves status to `suspended`; cleared on unsuspend.
  suspendedAt         DateTime?     @map("suspended_at")
  /// Free-form admin note shown in the Suspended banner so the tenant
  /// understands why writes are blocked. Optional.
  suspendedReason     String?       @map("suspended_reason")
  /// Remaining prepaid send quota. Decremented atomically in runSend on
  /// every provider send attempt (success or failure). When it reaches 0, the
  /// scheduler stops enqueueing for this tenant and any in-flight job
  /// fails the recipient (and same-campaign pending) with a quota error.
  /// Top-up is admin-driven via PATCH /api/admin/accounts/:id/quota.
  sendQuotaRemaining  Int           @default(0) @map("send_quota_remaining")
  /// Account type / role. Normal tenants (false) see a softened analytics view:
  /// soft bounces are folded into 送达 and 弹回邮箱率 is hidden. "Collaborators"
  /// (true) are trusted partners who see the real, unmodified deliverability
  /// data (including the true bounce rate). Toggled by admin in 租户管理.
  isCollaborator      Boolean       @default(false) @map("is_collaborator")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  members                AccountUser[]
  senderDomains          SenderDomain[]
  contactLists           ContactList[]
  contacts               Contact[]
  suppressions           SuppressionEntry[]
  tags                   Tag[]
  templates              EmailTemplate[]
  campaigns              Campaign[]
  campaignRecipients     CampaignRecipient[]
  sendLogs               SendLog[]
  importJobs             ImportJob[]
  customTags             CustomTag[]
  segments               Segment[]
  quotaOrders            QuotaOrder[]
  commissionRecords      CommissionRecord[]
  emailChannels          AccountEmailChannel[]
  shopConnections        ShopConnection[]
  shopOrders             ShopOrder[]
  shopAutomations        ShopAutomation[]
  shopAbandonedCheckouts ShopAbandonedCheckout[]

  referredByChannel ReferralChannel? @relation(fields: [referredByChannelId], references: [id], onDelete: SetNull)

  @@index([referredByChannelId])
  @@map("accounts")
}

/// Join table: which email channels a tenant may send through. A tenant can be
/// assigned multiple channels; exactly one is flagged `isPrimary` (enforced by
/// a partial unique index in migration SQL) and is used as the default when
/// adding a sender domain.
model AccountEmailChannel {
  accountId      String   @map("account_id") @db.Uuid
  emailChannelId String   @map("email_channel_id") @db.Uuid
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  emailChannel EmailChannel @relation(fields: [emailChannelId], references: [id], onDelete: Restrict)

  @@id([accountId, emailChannelId])
  @@index([emailChannelId])
  @@map("account_email_channels")
}

enum AccountStatus {
  pending_activation
  active
  suspended

  @@map("account_status")
}

model AccountUser {
  accountId String   @map("account_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("owner")
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([accountId, userId])
  @@index([userId])
  @@map("account_users")
}

// ============================================================================
// Email Channels (platform-level)
// ============================================================================

enum EmailChannelStatus {
  active
  suspended
  retired

  @@map("email_channel_status")
}

model EmailChannel {
  id                            String           @id @default(uuid()) @db.Uuid
  /// Sending channel provider.
  provider                      String           @default("acs") @db.VarChar(16)
  name                          String
  rpsLimit                      Int              @map("rps_limit")
  rpmLimit                      Int              @map("rpm_limit")
  rphLimit                      Int              @map("rph_limit")
  rpdLimit                      Int              @map("rpd_limit")
  status                        EmailChannelStatus @default(active)
  // Azure Resource Manager handles for managing domains under this account.
  // All required to drive the Azure ARM SDK; secret is stored verbatim for
  // the MVP — production should encrypt at rest.
  azureTenantId                 String           @map("azure_tenant_id")
  azureClientId                 String           @map("azure_client_id")
  azureClientSecret             String           @map("azure_client_secret") @db.Text
  azureSubscriptionId           String           @map("azure_subscription_id")
  azureResourceGroup            String           @map("azure_resource_group")
  azureEmailServiceName         String           @map("azure_email_service_name")
  // Communication Service resource that verified domains get linked to
  // (Microsoft.Communication/communicationServices). Different resource type
  // than EmailService — same RG, but separate name. Required to actually
  // send mail through the domain. Nullable so existing channels (created
  // before this column existed) keep working — they'll be rejected at the
  // link step until an admin edits and fills it in.
  azureCommunicationServiceName String?          @map("azure_communication_service_name")
  /// Mailgun API settings. `mailgunApiBaseUrl` supports EU accounts
  /// (https://api.eu.mailgun.net) while defaulting to the US endpoint.
  mailgunApiKey                 String?          @map("mailgun_api_key") @db.Text
  mailgunApiBaseUrl             String?          @map("mailgun_api_base_url")
  mailgunWebhookSigningKey      String?          @map("mailgun_webhook_signing_key") @db.Text
  /// Platform-wide default. New tenant signups get a primary
  /// AccountEmailChannel link to this channel. At most one row may be true at a
  /// time — enforced by a partial unique index defined in migration SQL
  /// (Prisma 5 doesn't support partial unique constraints declaratively).
  isDefault                     Boolean          @default(false) @map("is_default")
  createdAt                     DateTime         @default(now()) @map("created_at")
  updatedAt                     DateTime         @updatedAt @map("updated_at")

  senderDomains SenderDomain[]
  accountLinks  AccountEmailChannel[]
  sendLogs      SendLog[]

  @@map("email_channels")
}

// ============================================================================
// Sender Domains
// ============================================================================

enum SenderDomainStatus {
  provisioning
  pending
  verified
  failed

  @@map("sender_domain_status")
}

model SenderDomain {
  id                  String             @id @default(uuid()) @db.Uuid
  accountId           String             @map("account_id") @db.Uuid
  emailChannelId      String             @map("email_channel_id") @db.Uuid
  domain              String
  // The five DNS records Azure asks for (Domain, SPF, DKIM, DKIM2, DMARC).
  // Stored as JSON because the record types are mixed (TXT + CNAME) and the
  // exact selectors vary per Azure region.
  verificationRecords Json               @map("verification_records")
  // Latest verificationStates per record from the provider, refreshed on `verify`.
  verificationStates  Json?              @map("verification_states")
  provisioningError   String?            @map("provisioning_error") @db.Text
  status              SenderDomainStatus @default(pending)
  lastCheckedAt       DateTime?          @map("last_checked_at")
  verifiedAt          DateTime?          @map("verified_at")
  // Set after an ACS domain has been added to the Communication Service's
  // CommunicationService.linkedDomains array. Without this, sending from
  // the domain returns 401 from ACS Email even if DNS is verified.
  linkedAt            DateTime?          @map("linked_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  emailChannel    EmailChannel     @relation(fields: [emailChannelId], references: [id], onDelete: Restrict)
  senderUsernames SenderUsername[]

  @@unique([accountId, domain])
  @@index([accountId])
  @@index([emailChannelId])
  @@map("sender_domains")
}

model SenderUsername {
  id              String   @id @default(uuid()) @db.Uuid
  senderDomainId  String   @map("sender_domain_id") @db.Uuid
  // Local part only — full address is `${username}@${senderDomain.domain}`.
  username        String
  displayName     String?  @map("display_name")
  // Azure ARM resource id — kept so we can delete by exact id later.
  azureResourceId String?  @map("azure_resource_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  senderDomain SenderDomain @relation(fields: [senderDomainId], references: [id], onDelete: Cascade)

  @@unique([senderDomainId, username])
  @@index([senderDomainId])
  @@map("sender_usernames")
}

// ============================================================================
// Contacts & Lists
// ============================================================================

enum SubscriptionStatus {
  subscribed
  unsubscribed
  bounced
  complained
  pending

  @@map("subscription_status")
}

model ContactList {
  id          String   @id @default(uuid()) @db.Uuid
  accountId   String   @map("account_id") @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  account         Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  memberships     ContactListMembership[]
  campaigns       CampaignList[]
  shopConnections ShopConnection[]

  @@unique([accountId, name])
  @@index([accountId])
  @@map("contact_lists")
}

model Contact {
  id                 String             @id @default(uuid()) @db.Uuid
  accountId          String             @map("account_id") @db.Uuid
  email              String
  firstName          String?            @map("first_name")
  lastName           String?            @map("last_name")
  phone              String?
  gender             String?
  country            String?
  state              String?
  city               String?
  zip                String?
  birthday           DateTime?          @db.Date
  language           String?
  subscriptionStatus SubscriptionStatus @default(subscribed) @map("subscription_status")
  source             String?
  unsubscribedAt     DateTime?          @map("unsubscribed_at")
  /// Latest PAID shop-order time (null = never ordered). Denormalised from
  /// shop_orders at ingest/backfill; drives the segment `order` rule.
  lastOrderedAt      DateTime?          @map("last_ordered_at")
  /// Count of paid/shipped shop orders. Denormalised from shop_orders so
  /// order-metric segments can be evaluated as plain Contact predicates.
  orderCount         Int                @default(0) @map("order_count")
  /// Sum of paid/shipped shop order values. Same currency semantics as
  /// shop_orders.value: stores are expected to be single-currency in v1.
  orderAmount        Decimal            @default(0) @map("order_amount") @db.Decimal(18, 2)
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  account     Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  memberships ContactListMembership[]
  tags        ContactTag[]

  @@unique([accountId, email])
  @@index([accountId, subscriptionStatus])
  @@index([accountId, lastOrderedAt])
  @@index([accountId, orderCount])
  @@index([accountId, orderAmount])
  // NOTE: no [accountId, email] non-unique index — the @@unique above already
  // produces a btree on (accountId, email) which PG will use for prefix /
  // equality lookups. Keeping a duplicate non-unique would just double write
  // amplification on contact upserts.
  @@map("contacts")
}

model ContactListMembership {
  listId    String   @map("list_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  addedAt   DateTime @default(now()) @map("added_at")

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@index([contactId])
  @@map("contact_list_memberships")
}

enum SuppressionReason {
  hard_bounce
  soft_bounce_threshold
  complaint
  unsubscribe
  manual

  @@map("suppression_reason")
}

model SuppressionEntry {
  id        String            @id @default(uuid()) @db.Uuid
  accountId String            @map("account_id") @db.Uuid
  email     String
  reason    SuppressionReason
  meta      Json?
  createdAt DateTime          @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, email])
  @@index([accountId])
  @@map("suppression_entries")
}

// ============================================================================
// Tags
// ============================================================================

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  name      String
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  account  Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contacts ContactTag[]

  @@unique([accountId, name])
  @@map("tags")
}

model ContactTag {
  tagId     String   @map("tag_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([tagId, contactId])
  @@map("contact_tags")
}

// ============================================================================
// Custom Tags (per-account placeholders for subject / preheader / body)
//
// Users define a tag like `greeting` with N possible values; at send time
// worker-sender substitutes `{{tag:greeting}}` in the email with one value
// chosen at random per recipient. See apps/worker-sender/src/custom-tags.ts.
// ============================================================================

model CustomTag {
  id        String   @id @default(uuid()) @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  /// Token used in placeholders, e.g. {{tag:greeting}}. Lowercase enforced in API layer.
  name      String
  /// Array of candidate replacement strings; one is chosen per recipient.
  values    String[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, name])
  @@index([accountId])
  @@map("custom_tags")
}

// ============================================================================
// Email Templates
// ============================================================================

enum TemplateScope {
  system
  user

  @@map("template_scope")
}

model EmailTemplate {
  id         String        @id @default(uuid()) @db.Uuid
  accountId  String?       @map("account_id") @db.Uuid
  scope      TemplateScope @default(user)
  name       String
  thumbnail  String?
  mjml       String?       @db.Text
  html       String        @db.Text
  designJson Json?         @map("design_json")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  account   Account?   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([accountId])
  @@map("email_templates")
}

// ============================================================================
// Campaigns
// ============================================================================

enum CampaignStatus {
  draft
  scheduled
  sending
  sent
  paused
  failed
  canceled

  @@map("campaign_status")
}

model Campaign {
  id               String         @id @default(uuid()) @db.Uuid
  accountId        String         @map("account_id") @db.Uuid
  name             String
  subject          String
  preheader        String?
  fromName         String         @map("from_name")
  fromEmail        String         @map("from_email")
  replyTo          String?        @map("reply_to")
  templateId       String?        @map("template_id") @db.Uuid
  mjml             String?        @db.Text
  html             String?        @db.Text
  designJson       Json?          @map("design_json")
  /// Which editor produced the body. `visual` = Easy Email drag-drop (writes
  /// designJson + mjml + html); `html` = raw HTML editor (writes html only,
  /// designJson/mjml stay null). The campaign wizard's step-2 component
  /// branches on this; switching modes clears all body fields by design so
  /// we never end up with stale Easy Email state polluting a hand-written
  /// HTML campaign or vice versa.
  editorMode       String         @default("visual") @map("editor_mode")
  // Pre-rendered preview thumbnail (WebP) shipped to the campaign list so the
  // page doesn't have to ferry the full HTML body and render 50 iframes —
  // see CampaignListPage. Rendered server-side (headless Chromium) by
  // worker-thumbnail and stored as a public-bucket URL. `thumbnailPending`
  // is set true whenever the HTML changes and cleared once the render lands,
  // so the list can show a placeholder + poll until it's ready.
  thumbnail        String?
  thumbnailPending Boolean        @default(false) @map("thumbnail_pending")
  status           CampaignStatus @default(draft)
  scheduledAt      DateTime?      @map("scheduled_at")
  sendingStartedAt DateTime?      @map("sending_started_at")
  sentAt           DateTime?      @map("sent_at")
  totalRecipients  Int            @default(0) @map("total_recipients")
  utmEnabled       Boolean        @default(true) @map("utm_enabled")
  utmSource        String?        @map("utm_source")
  utmMedium        String?        @map("utm_medium")
  utmCampaign      String?        @map("utm_campaign")
  trackClicks      Boolean        @default(true) @map("track_clicks")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  account    Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  template   EmailTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  lists      CampaignList[]
  segments   CampaignSegment[]
  recipients CampaignRecipient[]
  senders    CampaignSender[]
  sendLogs   SendLog[]

  @@index([accountId, status])
  @@index([accountId, createdAt])
  @@index([status])
  @@map("campaigns")
}

/// Extra "from" addresses a campaign rotates through. `Campaign.fromEmail`/
/// `fromName` always equal the position-0 sender (kept for previews, the
/// list view, and as the tick scheduler's channel-routing key). When a campaign
/// has >1 sender, each recipient is assigned one in round-robin at
/// materialisation time (see CampaignRecipient.fromEmail). All senders must
/// resolve to verified domains under their assigned email channels.
model CampaignSender {
  id         String @id @default(uuid()) @db.Uuid
  campaignId String @map("campaign_id") @db.Uuid
  fromEmail  String @map("from_email")
  fromName   String @map("from_name")
  /// 0-based slot; position 0 mirrors Campaign.fromEmail. Drives the
  /// round-robin order (recipient i → sender at position i % senderCount).
  position   Int

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, fromEmail])
  @@index([campaignId])
  @@map("campaign_senders")
}

model CampaignList {
  campaignId String @map("campaign_id") @db.Uuid
  listId     String @map("list_id") @db.Uuid
  /// 0-based index of this list in the order the user selected them. Drives
  /// {{list_name}}: a recipient in several target lists resolves to the FIRST
  /// (lowest position) one they belong to. Legacy rows default to 0.
  position   Int    @default(0)

  campaign Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  list     ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([campaignId, listId])
  @@map("campaign_lists")
}

/// Saved dynamic audience. `definition` is a versioned JSON tree validated
/// against the SegmentDefinitionSchema in @sendmast/shared. `cachedCount`
/// + `cachedAt` are display-only optimisations refreshed by /refresh or
/// /preview; the campaign send path always re-evaluates from scratch so
/// stale caches can never cause wrong-audience sends.
model Segment {
  id          String    @id @default(uuid()) @db.Uuid
  accountId   String    @map("account_id") @db.Uuid
  name        String
  description String?
  definition  Json
  cachedCount Int?      @map("cached_count")
  cachedAt    DateTime? @map("cached_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  account   Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaigns CampaignSegment[]

  @@unique([accountId, name])
  @@index([accountId, createdAt])
  @@map("segments")
}

model CampaignSegment {
  campaignId String @map("campaign_id") @db.Uuid
  segmentId  String @map("segment_id") @db.Uuid

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  segment  Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@id([campaignId, segmentId])
  @@map("campaign_segments")
}

enum RecipientStatus {
  pending
  queued
  sent
  failed
  skipped

  @@map("recipient_status")
}

/// Marker table — one row per campaign whose recipient detail has been
/// moved out of `campaign_recipients` into ClickHouse. The archive job
/// uses this as a "do not re-archive" guard, and the read API consults
/// it to decide whether to query PG or CH for a campaign's recipients.
model CampaignArchiveState {
  campaignId     String   @id @map("campaign_id") @db.Uuid
  archivedAt     DateTime @default(now()) @map("archived_at")
  recipientCount Int      @map("recipient_count")

  @@map("campaign_archive_state")
}

model CampaignRecipient {
  id           String          @id @default(uuid()) @db.Uuid
  accountId    String          @map("account_id") @db.Uuid
  campaignId   String          @map("campaign_id") @db.Uuid
  contactId    String          @map("contact_id") @db.Uuid
  email        String
  status       RecipientStatus @default(pending)
  messageId    String?         @map("message_id")
  errorMessage String?         @map("error_message")
  sentAt       DateTime?       @map("sent_at")
  /// Round-robin sender assigned at materialisation when the campaign has
  /// multiple senders. NULL = use Campaign.fromEmail/fromName (single-sender
  /// campaigns and all rows created before this feature).
  fromEmail    String?         @map("from_email")
  fromName     String?         @map("from_name")
  /// Email channel this recipient's send is routed through, resolved from the
  /// assigned sender's domain at materialisation. NULL = legacy rows; the
  /// dispatcher falls back to resolving from the from-address domain.
  emailChannelId String?       @map("email_channel_id") @db.Uuid
  /// Name of the campaign target list THIS contact belongs to, captured at
  /// materialisation. When the contact is in several of the campaign's target
  /// lists this is the FIRST one (lowest CampaignList.position) they belong to.
  /// Powers the {{list_name}} system tag without a send-time join and frozen
  /// against later membership changes. NULL = matched only via a segment, or
  /// legacy pre-feature rows.
  listName     String?         @map("list_name")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sendLogs SendLog[]

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([accountId, status])
  @@index([messageId])
  @@index([emailChannelId, status])
  @@map("campaign_recipients")
}

// ============================================================================
// Send Logs
// ============================================================================

/// One row per provider send attempt. Append-only; multiple rows per recipient
/// allowed (future retries). Pre-flight failures (no html / suspended channel
/// / transport build failure) are NOT logged here — those never reach provider APIs.
model SendLog {
  id               String  @id @default(uuid()) @db.Uuid
  accountId        String  @map("account_id") @db.Uuid // tenant
  emailChannelId   String? @map("email_channel_id") @db.Uuid // SetNull on channel delete to retain history
  /// `campaign` or `automation`; kept as text so future send sources can be
  /// added without an enum migration.
  source           String  @default("campaign")
  campaignId       String? @map("campaign_id") @db.Uuid
  recipientId      String? @map("recipient_id") @db.Uuid
  automationId     String? @map("automation_id") @db.Uuid
  automationSendId String? @map("automation_send_id") @db.Uuid

  fromAddress String  @map("from_address")
  fromName    String? @map("from_name")
  toAddress   String  @map("to_address")

  ok              Boolean
  /// Provider terminal status (Succeeded / Failed / Canceled) or `Http<code>` / `Error`
  /// when the SDK threw before reaching a terminal LRO state.
  providerStatus  String?  @map("provider_status")
  messageId       String?  @map("message_id")
  errorCode       String?  @map("error_code")
  errorMessage    String?  @map("error_message") @db.Text
  latencyMs       Int?     @map("latency_ms")
  /// Raw provider response body (success: minimal; failure: cherry-picked error).
  /// Request body is intentionally NOT stored — it's large and the campaign
  /// row already carries fromEmail / subject / html.
  responsePayload Json?    @map("response_payload")
  sentAt          DateTime @default(now()) @map("sent_at")

  account              Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  emailChannel         EmailChannel?       @relation(fields: [emailChannelId], references: [id], onDelete: SetNull)
  campaign             Campaign?           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipient            CampaignRecipient?  @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  automation           ShopAutomation?     @relation(fields: [automationId], references: [id], onDelete: Cascade)
  automationSend       ShopAutomationSend? @relation(fields: [automationSendId], references: [id], onDelete: Cascade)

  @@index([campaignId, sentAt])
  @@index([recipientId, sentAt])
  @@index([automationId, sentAt])
  @@index([automationSendId, sentAt])
  @@index([source, sentAt])
  @@index([emailChannelId, ok, sentAt])
  @@index([accountId, sentAt])
  @@map("send_logs")
}

// ============================================================================
// Import Jobs
// ============================================================================

enum ImportStatus {
  pending
  processing
  completed
  failed

  @@map("import_status")
}

model ImportJob {
  id            String       @id @default(uuid()) @db.Uuid
  accountId     String       @map("account_id") @db.Uuid
  listId        String?      @map("list_id") @db.Uuid
  filename      String
  storageKey    String       @map("storage_key")
  status        ImportStatus @default(pending)
  totalRows     Int?         @map("total_rows")
  processedRows Int          @default(0) @map("processed_rows")
  insertedRows  Int          @default(0) @map("inserted_rows")
  updatedRows   Int          @default(0) @map("updated_rows")
  skippedRows   Int          @default(0) @map("skipped_rows")
  errorMessage  String?      @map("error_message")
  startedAt     DateTime?    @map("started_at")
  finishedAt    DateTime?    @map("finished_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@map("import_jobs")
}

// ============================================================================
// Referral / Commission
// ============================================================================

/// Platform-managed referral channel (a third-party partner / reseller).
/// Each row exposes a short URL-safe `code` that anchors a public referral
/// link: `https://app/signup?ref=<code>`. When a visitor signs up while
/// carrying that code, we stamp `accounts.referredByChannelId` and from
/// then on every paid QuotaOrder for that account spawns a CommissionRecord
/// at the prevailing global rate.
///
/// `payoutInfo` is intentionally free-form text (bank / Alipay / WeChat /
/// whatever the partner gave us) — we never auto-transfer; settlement is
/// off-platform, the per-month CSV export is the operator's source of truth.
model ReferralChannel {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(32)
  name       String
  contact    String?
  payoutInfo String?  @map("payout_info") @db.Text
  notes      String?  @db.Text
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  accounts          Account[]
  commissionRecords CommissionRecord[]

  @@map("referral_channels")
}

/// One row per paid QuotaOrder placed by a referred account. `orderId` is
/// UNIQUE so the create runs exactly once even if a payment webhook
/// is retried after we already credited the order. `ratePercent` is the
/// snapshot of the global setting at the moment of creation — later edits
/// to ReferralSetting.ratePercent do NOT rewrite history.
model CommissionRecord {
  id             String   @id @default(uuid()) @db.Uuid
  channelId      String   @map("channel_id") @db.Uuid
  orderId        String   @unique @map("order_id") @db.Uuid
  accountId      String   @map("account_id") @db.Uuid
  orderAmountCny Decimal  @map("order_amount_cny") @db.Decimal(10, 2)
  ratePercent    Decimal  @map("rate_percent") @db.Decimal(5, 2)
  commissionCny  Decimal  @map("commission_cny") @db.Decimal(10, 2)
  /// Mirrors `quota_orders.paid_at` — copied here so per-month export can
  /// `WHERE paid_at >= ... AND paid_at < ...` on a single indexed column
  /// without joining quota_orders.
  paidAt         DateTime @map("paid_at")
  createdAt      DateTime @default(now()) @map("created_at")

  channel ReferralChannel @relation(fields: [channelId], references: [id], onDelete: Restrict)
  account Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([channelId, paidAt])
  @@index([paidAt])
  @@map("commission_records")
}

/// Singleton — only one row exists, primary key hard-coded to 'singleton'.
/// Holds the platform-wide commission rate (percent, e.g. 15.00 = 15%)
/// applied to every new CommissionRecord. Edits don't rewrite past
/// CommissionRecord rows (those snapshot the rate at insert time).
model ReferralSetting {
  id          String   @id @default("singleton")
  ratePercent Decimal  @default(15.00) @map("rate_percent") @db.Decimal(5, 2)
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("referral_settings")
}

// ============================================================================
// Shop Integrations (shopyy / OEMSAAS)
//
// A tenant connects an external e-commerce store via an OAuth-like flow. We
// store the developer-app `devToken` used to call the OpenAPI gateway, ingest
// order/checkout webhooks, attribute revenue back to email campaigns, and run
// fixed buyer-facing automations (registration / paid / shipped / abandoned-cart).
// ============================================================================

enum ShopProvider {
  shopyy

  @@map("shop_provider")
}

enum ShopConnectionStatus {
  active
  expired
  revoked

  @@map("shop_connection_status")
}

/// One connected store per row. `devToken` is the developer-app token returned
/// by the authorize exchange and used for every OpenAPI call; stored verbatim
/// for the MVP (mirrors EmailChannel.azureClientSecret) — encrypt at rest later.
/// `webhookSecret` is our own per-connection secret used to HMAC-verify inbound
/// webhooks.
model ShopConnection {
  id              String               @id @default(uuid()) @db.Uuid
  accountId       String               @map("account_id") @db.Uuid
  provider        ShopProvider         @default(shopyy)
  externalStoreId String               @map("external_store_id")
  shopName        String?              @map("shop_name")
  shopDomain      String?              @map("shop_domain")
  mainDomain      String?              @map("main_domain")
  /// Merchant-confirmed public storefront URL. Preferred over provider domains
  /// in customer-facing automation links.
  storeUrl        String?              @map("store_url")
  brandId         String?              @map("brand_id")
  timeZone        String?              @map("time_zone")
  openapiDomain   String               @map("openapi_domain")
  webhookBaseurl  String?              @map("webhook_baseurl")
  appExternalId   String?              @map("app_external_id")
  appKey          String?              @map("app_key")
  appName         String?              @map("app_name")
  devToken        String               @map("dev_token") @db.Text
  webhookSecret   String?              @map("webhook_secret")
  /// Shopyy webhook row IDs created/owned by this connection. Persisted at bind
  /// time so disconnect can delete exactly these rows without URL heuristics.
  webhookIds      Int[]                @default([]) @map("webhook_ids")
  status          ShopConnectionStatus @default(active)
  storeExpiredAt  DateTime?            @map("store_expired_at")
  connectedAt     DateTime             @default(now()) @map("connected_at")
  lastSyncAt      DateTime?            @map("last_sync_at")
  /// Auto-created "店铺客户" list this store's customers are funnelled into
  /// (customers/create + order webhooks + initial full sync).
  customerListId  String?              @map("customer_list_id") @db.Uuid
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  account            Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customerList       ContactList?            @relation(fields: [customerListId], references: [id], onDelete: SetNull)
  orders             ShopOrder[]
  automations        ShopAutomation[]
  abandonedCheckouts ShopAbandonedCheckout[]

  @@unique([provider, externalStoreId])
  @@index([accountId])
  @@map("shop_connections")
}

/// Ingested store order. `value`/`currency`/`status` are normalised; `raw`
/// keeps the provider payload for debugging and future field needs. Revenue
/// attribution is resolved at ingest (last-click within 7d) and snapshotted
/// onto `attributed*`; the ClickHouse `orders`/`attributions` tables are the
/// analytics source of truth, this PG row is the operational record.
model ShopOrder {
  id                     String   @id @default(uuid()) @db.Uuid
  accountId              String   @map("account_id") @db.Uuid
  shopConnectionId       String   @map("shop_connection_id") @db.Uuid
  externalOrderId        String   @map("external_order_id")
  orderNo                String?  @map("order_no")
  customerEmail          String   @map("customer_email")
  contactId              String?  @map("contact_id") @db.Uuid
  value                  Decimal  @db.Decimal(18, 2)
  currency               String
  status                 String
  orderTime              DateTime @map("order_time")
  attributedCampaignId   String?  @map("attributed_campaign_id") @db.Uuid
  attributedContactId    String?  @map("attributed_contact_id") @db.Uuid
  attributionModel       String?  @map("attribution_model")
  /// Flow this order is hard-attributed to (recall link carried sm_mid=sendId).
  attributedAutomationId String?  @map("attributed_automation_id") @db.Uuid
  /// The exact flow send (shop_automation_sends.id) that earned the conversion.
  attributedSendId       String?  @map("attributed_send_id") @db.Uuid
  raw                    Json?
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  account        Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  shopConnection ShopConnection @relation(fields: [shopConnectionId], references: [id], onDelete: Cascade)

  @@unique([shopConnectionId, externalOrderId])
  @@index([accountId, orderTime])
  @@index([attributedCampaignId])
  @@index([attributedAutomationId])
  @@index([customerEmail])
  @@map("shop_orders")
}

enum ShopAutomationType {
  customer_registered
  order_paid
  order_shipped
  abandoned_cart

  @@map("shop_automation_type")
}

/// One configurable automation per (store, type). Each is backed by a hidden
/// system Campaign so triggered 1:1 sends reuse the full campaign pipeline
/// (quota, tracking, events, deliverability stats).
model ShopAutomation {
  id               String             @id @default(uuid()) @db.Uuid
  accountId        String             @map("account_id") @db.Uuid
  shopConnectionId String             @map("shop_connection_id") @db.Uuid
  type             ShopAutomationType
  enabled          Boolean            @default(false)
  /// Legacy link to a source template; content is now stored inline below.
  /// Kept so existing rows can backfill their content and the worker can fall
  /// back to a template when inline html is missing.
  templateId       String?            @map("template_id") @db.Uuid
  /// Inline email content (seeded from a system template, then editable in
  /// place). `html` is what gets sent; `designJson` re-opens the block editor.
  html             String?            @db.Text
  mjml             String?            @db.Text
  designJson       Json?              @map("design_json")
  thumbnail        String?
  /// Optional inbox preview text (preheader), injected as a hidden span on send.
  preheader        String?
  senderDomainId   String?            @map("sender_domain_id") @db.Uuid
  fromEmail        String?            @map("from_email")
  fromName         String?            @map("from_name")
  subject          String?
  /// abandoned_cart only: minutes to wait after an order is created before the
  /// recall fires (skipped if the order has been paid by then).
  delayMinutes     Int                @default(60) @map("delay_minutes")
  /// Backing hidden system campaign id; recipients are attached to it so the
  /// existing send/track/analytics stack applies unchanged.
  systemCampaignId String?            @map("system_campaign_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  account        Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  shopConnection ShopConnection       @relation(fields: [shopConnectionId], references: [id], onDelete: Cascade)
  sends          ShopAutomationSend[]
  sendLogs       SendLog[]
  steps          ShopAutomationStep[]

  @@unique([shopConnectionId, type])
  @@index([accountId])
  @@map("shop_automations")
}

/// abandoned_cart only: an ordered recovery round (up to 5 per automation).
/// Each round fires its own send `delayMinutes` after order creation (absolute,
/// strictly increasing across rounds) with its own template + subject. The
/// shared sender (from address) lives on the parent `ShopAutomation`. Other
/// automation types ignore steps and keep using the parent's template/subject.
model ShopAutomationStep {
  id                  String   @id @default(uuid()) @db.Uuid
  automationId        String   @map("automation_id") @db.Uuid
  /// 1-based round order; delays must strictly increase with stepIndex.
  stepIndex           Int      @map("step_index")
  /// Legacy link to a source template; content is now stored inline below.
  templateId          String?  @map("template_id") @db.Uuid
  /// Inline email content for this round (seeded from a template, then editable).
  html                String?  @db.Text
  mjml                String?  @db.Text
  designJson          Json?    @map("design_json")
  thumbnail           String?
  /// Optional inbox preview text (preheader) for this round.
  preheader           String?
  subject             String?
  /// Store coupon code shown in this round's recall email; null = no coupon.
  couponCode          String?  @map("coupon_code")
  /// Snapshot of the coupon's discount kind: 'percent' | 'amount' (null = unknown).
  couponDiscountKind  String?  @map("coupon_discount_kind")
  /// Snapshot of the coupon's discount value (percent off, or amount off).
  couponDiscountValue Float?   @map("coupon_discount_value")
  /// Minutes after order creation this round fires (absolute, not incremental).
  delayMinutes        Int      @map("delay_minutes")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  automation ShopAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@unique([automationId, stepIndex])
  @@map("shop_automation_steps")
}

/// A single flow-message send — the Klaviyo-style first-class, independently
/// tracked transactional/automation email (NOT a campaign). Replaces the old
/// hidden-campaign-per-send borrow. Open/click/unsubscribe events and provider
/// delivery/bounce reports resolve back to this row (by `id` for the tracking
/// pixel/links, by `messageId` for provider reports). `@@unique([automationId,
/// dedupKey])` makes a re-delivered webhook (same order/checkout) idempotent.
model ShopAutomationSend {
  id           String    @id @default(uuid()) @db.Uuid
  accountId    String    @map("account_id") @db.Uuid
  automationId String    @map("automation_id") @db.Uuid
  dedupKey     String    @map("dedup_key")
  email        String
  contactId    String?   @map("contact_id") @db.Uuid
  /// Template this send renders. Snapshots the round's template for multi-round
  /// abandoned-cart (where each round has its own); null = use automation's.
  templateId   String?   @map("template_id") @db.Uuid
  /// Inline email content snapshotted at enqueue time (preferred over template).
  html         String?   @db.Text
  /// Inbox preview text snapshotted at enqueue time; injected as a hidden span.
  preheader    String?
  /// Lifecycle: pending → queued → sent | failed | skipped.
  status       String    @default("pending")
  /// Provider operation id, echoed back as messageId on delivery/bounce reports where supported.
  messageId    String?   @map("message_id")
  /// Email channel the send is routed through (resolved from the sender domain).
  emailChannelId String? @map("email_channel_id") @db.Uuid
  /// Sender snapshot at send time.
  fromEmail    String?   @map("from_email")
  fromName     String?   @map("from_name")
  subject      String?
  /// Per-send merge values ({{order_total}}, {{tracking_url}}, ...).
  mergeVars    Json?     @map("merge_vars")
  errorMessage String?   @map("error_message")
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  automation ShopAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  sendLogs   SendLog[]

  @@unique([automationId, dedupKey])
  @@index([accountId, createdAt])
  @@index([status, createdAt])
  @@index([messageId])
  @@map("shop_automation_sends")
}

/// Abandoned checkout captured from shopyy (event or poll). Recovery send is
/// scheduled `delayMinutes` after `abandonedAt`; before sending we re-check
/// `shop_orders` for a matching purchase and skip if the buyer converted.
model ShopAbandonedCheckout {
  id                  String    @id @default(uuid()) @db.Uuid
  accountId           String    @map("account_id") @db.Uuid
  shopConnectionId    String    @map("shop_connection_id") @db.Uuid
  externalCheckoutId  String    @map("external_checkout_id")
  customerEmail       String    @map("customer_email")
  contactId           String?   @map("contact_id") @db.Uuid
  value               Decimal?  @db.Decimal(18, 2)
  currency            String?
  recoveryUrl         String?   @map("recovery_url")
  abandonedAt         DateTime  @map("abandoned_at")
  recoveredAt         DateTime? @map("recovered_at")
  recoveryEmailSentAt DateTime? @map("recovery_email_sent_at")
  status              String    @default("pending")
  raw                 Json?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  account        Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  shopConnection ShopConnection @relation(fields: [shopConnectionId], references: [id], onDelete: Cascade)

  @@unique([shopConnectionId, externalCheckoutId])
  @@index([accountId, abandonedAt])
  @@map("shop_abandoned_checkouts")
}
