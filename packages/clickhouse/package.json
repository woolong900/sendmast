{
  "name": "@sendmast/clickhouse",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "migrate": "dotenv -e ../../.env -- tsx src/migrate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit --tsBuildInfoFile node_modules/.cache/.tsbuildinfo"
  },
  "dependencies": {
    "@clickhouse/client": "^1.8.1"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
